{
  "target": "aarch64",
  "version": 1,
  "methodology": {
    "primaryPaper": "research/llvm-energy-scopes.pdf",
    "approach": "Instruction-level machine analysis for AArch64. Bucket costs are calibrated against ARM Cortex-A energy characterization literature (Georgiou 2019, ARM A-profile optimization guide) and are relative to integer ALU as baseline.",
    "attribution": [
      "Assign per-instruction energy from an explicit model.",
      "Aggregate raw energy at block and function scope.",
      "Apply block-frequency weighting (loop-depth heuristic: 10^depth) for hotspot ranking.",
      "Propagate debug locations into source-line energy scopes."
    ],
    "limitations": [
      "This model is comparative and static; costs are relative, not calibrated physical Joule measurements.",
      "Costs reflect Cortex-A class big cores; Cortex-M embedded or Apple Silicon may differ significantly.",
      "Unmapped opcodes fall back to bucket heuristics or the default fallback cost."
    ]
  },
  "references": [
    "research/Kyriakos_Georgiou_Energy_Transparency_for_Deeply_Embedded_Programs.pdf",
    "research/llvm-energy-scopes.pdf",
    "ARM Cortex-A Series Programmer's Guide for ARMv8-A, 2024",
    "ARM Neoverse V1 Software Optimization Guide, 2022"
  ],
  "defaultFallbackCost": 1.0,
  "opcodeBuckets": {
    "integer_alu": 1.0,
    "load": 2.0,
    "store": 2.2,
    "branch": 1.6,
    "call": 3.0,
    "compare": 1.2,
    "fp_or_vector_fallback": 2.8
  },
